from abc import ABC, abstractmethod

class Pago(ABC):
    @abstractmethod
    def procesar_pago(self):
        pass

class TarjetaCredito(Pago):
    def procesar_pago(self):
        return "Procesando el pago mediante Tarjeta de Crédito."

class PayPal(Pago):
    def procesar_pago(self):
        return "Procesando el pago a través de PayPal."
